PORT=3002
SESSION_SECRET=changez-moi-vers-une-chaine-longue-et-aleatoire
# Base fichier (recommandé : ./data/site.db). Pour une base en RAM, mettez exactement :memory: (pas un chemin).
DATABASE_PATH=./data/site.db
ADMIN_USERNAME=admin
# Réaligné en base à chaque démarrage du serveur
ADMIN_PASSWORD=changeme-en-production

# --- Vercel (voir README · « Déploiement Vercel ») ---
# Ne pas pousser de .env : définir ces clés dans le tableau Environment Variables du projet.
# Obligatoire en prod :
# SESSION_SECRET=<chaîne longue aléatoire>
# ADMIN_USERNAME / ADMIN_PASSWORD
# Base SQLite writable sur l’isolate serverless :
# DATABASE_PATH=/tmp/site.db
