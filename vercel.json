{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "{*.{html,jsx,js},assets/**,server/legal-defaults/**/*.html,server/**/*.sql}"
    }
  }
}
